# =============================================================================
# Panopticon environment variables
#
# Copy this file to `.env` and fill in only the values you actually need.
# `.env` is gitignored — never commit it.
#
# Phase 1 requires NONE of these. They are all forward-looking.
# =============================================================================


# --- AI Coaching backend (Phase 5) -------------------------------------------
# Configure ONE of these. The coaching layer dispatches to whichever is set.
# Default behavior with all three unset: coaching layer is disabled.

# Option A: Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...

# Option B: OpenAI
# OPENAI_API_KEY=sk-...

# Option C: Local Ollama (no key, just a base URL)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:70b


# --- Sync target (Phase 6, off by default) -----------------------------------
# Configure ONE of these only if you want phone <-> desktop sync.

# Option A: Self-hosted REST endpoint
# PANOPTICON_SYNC_URL=https://sync.example.com
# PANOPTICON_SYNC_TOKEN=long-random-token-you-generated

# Option B: Firebase (your own project)
# FIREBASE_PROJECT_ID=
# FIREBASE_API_KEY=
# (other Firebase config as needed)


# --- Development flags -------------------------------------------------------
# DEBUG_VERBOSE_LOGGING=false
# DEBUG_DUMP_EVENTS_TO_STDOUT=false
